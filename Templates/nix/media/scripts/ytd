#!/usr/bin/env bash
set -euo pipefail

resolve_app_root() {
  if [ -n "${APP_ROOT:-}" ]; then
    printf '%s\n' "$APP_ROOT"
    return 0
  fi

  if [ -z "${APP_NAME:-}" ]; then
    printf 'APP_NAME is not set\n' >&2
    exit 1
  fi

  if [ -z "${HOME:-}" ] || [ "$HOME" = "/homeless-shelter" ]; then
    printf 'No usable HOME for runtime path resolution\n' >&2
    exit 1
  fi

  printf '%s/%s\n' "$HOME" "$APP_NAME"
}

main() {
  set_defaults
  parse_arguments "$@"
  execute_command
}

set_defaults() {
  local app_root
  app_root="$(resolve_app_root)"

  URL=""
  FMT="best"
  DIR="${APP_DOWNLOADS:-${app_root}/Downloads}"
  CFG_DIR="${APP_CFG_YTD:-${app_root}/.config/ytd}"
  CFG="${CFG_DIR}/yt-dlp.conf"
}

usage() {
  printf 'Usage: ytd <url> [quality]\n' >&2
  printf 'Quality: best, 1080p, 720p, 480p, audio\n' >&2
  exit 1
}

parse_arguments() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      audio|best|1080p|720p|480p)
        FMT="$1"
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        usage
        ;;
      *)
        URL="$1"
        break
        ;;
    esac
    shift
  done

  [ -n "$URL" ] || usage
}

execute_command() {
  mkdir -p "$DIR" "$(dirname "$CFG")"

  case "$FMT" in
    best)
      exec "@cmd@" --config-location "$CFG" "$URL"
      ;;
    audio)
      exec "@cmd@" \
        --config-location "$CFG" \
        --extract-audio \
        --audio-format mp3 \
        --output "${DIR}/%(title)s.%(ext)s" \
        "$URL"
      ;;
    *)
      exec "@cmd@" \
        --config-location "$CFG" \
        --format "bestvideo[height<=${FMT%p}]+bestaudio/best[height<=${FMT%p}]" \
        --output "${DIR}/%(title)s.%(ext)s" \
        "$URL"
      ;;
  esac
}

main "$@"
