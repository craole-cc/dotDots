#!/usr/bin/env bash
set -euo pipefail

resolve_app_root() {
  if [ -n "${APP_ROOT:-}" ]; then
    printf '%s\n' "$APP_ROOT"
    return 0
  fi

  if [ -z "${APP_NAME:-}" ]; then
    printf 'APP_NAME is not set\n' >&2
    exit 1
  fi

  if [ -z "${HOME:-}" ] || [ "$HOME" = "/homeless-shelter" ]; then
    printf 'No usable HOME for runtime path resolution\n' >&2
    exit 1
  fi

  printf '%s/%s\n' "$HOME" "$APP_NAME"
}

main() {
  local app_root cfg_dir scripts_dir

  app_root="$(resolve_app_root)"
  cfg_dir="${APP_CFG_MPV:-${app_root}/.config/mpv}"
  scripts_dir="${cfg_dir}/scripts"

  mkdir -p "${scripts_dir}"

  if [ ! -f "${scripts_dir}/ytdl_hook.lua" ]; then
    cp "@mpv@/share/mpv/scripts/ytdl_hook.lua" "${scripts_dir}/"
  fi

  exec "@cmd@" --config-dir="${cfg_dir}" "$@"
}

main "$@"
