#!/usr/bin/env bash
set -euo pipefail

main() {
  set_defaults
  parse_arguments "$@"
  execute_command
}

set_defaults() {
  URL=""
  FMT="best"
  DIR="${@downloadsVar@:?@downloadsVar@ is not set}"
  CFG_DIR="${@cfgVar@:?@cfgVar@ is not set}"
  CFG="${CFG_DIR}/yt-dlp.conf"
}

usage() {
  printf 'Usage: ytd <url> [quality]\n' >&2
  printf 'Quality: best, 1080p, 720p, 480p, audio\n' >&2
  exit 1
}

parse_arguments() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      best|1080p|720p|480p|audio)
        FMT="$1"
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        usage
        ;;
      *)
        if [ -z "$URL" ]; then
          URL="$1"
        else
          printf 'Unexpected extra argument: %s\n' "$1" >&2
          usage
        fi
        ;;
    esac
    shift
  done

  [ -n "$URL" ] || usage
}

execute_command() {
  mkdir -p "$DIR" "$(dirname "$CFG")"
  case "$FMT" in
    best)
      "@cmd@" --config-location "$CFG" \
        --output "${DIR}/%(title)s.%(ext)s" \
        "$URL"
      ;;
    audio)
      "@cmd@" --config-location "$CFG" \
        --extract-audio --audio-format mp3 \
        --output "${DIR}/%(title)s.%(ext)s" \
        "$URL"
      ;;
    *)
      "@cmd@" --config-location "$CFG" \
        --format "bestvideo[height<=${FMT%p}]+bestaudio/best[height<=${FMT%p}]" \
        --output "${DIR}/%(title)s.%(ext)s" \
        "$URL"
      ;;
  esac
}

main "$@"
