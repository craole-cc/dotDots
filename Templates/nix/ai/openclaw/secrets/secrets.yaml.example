# secrets/secrets.yaml.example
# Copy this file to secrets/secrets.yaml, fill in real values,
# then encrypt with: sops --encrypt --in-place secrets/secrets.yaml
#
# The plaintext secrets/secrets.yaml is in .gitignore.
# Only secrets/secrets.yaml.enc (or the sops-encrypted yaml) is committed.

openclaw:
  api-secret: "REPLACE_ME_WITH_REAL_SECRET"
  tls:
    key: |
      -----BEGIN PRIVATE KEY-----
      REPLACE_WITH_REAL_KEY
      -----END PRIVATE KEY-----
    cert: |
      -----BEGIN CERTIFICATE-----
      REPLACE_WITH_REAL_CERT
      -----END CERTIFICATE-----
