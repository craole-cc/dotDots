# secrets/.sops.yaml.example
# Copy to .sops.yaml at the repo root.
# Replace the age public key with the output of: age-keygen -o ~/.config/sops/age/keys.txt
# (age-keygen prints the PUBLIC key to stdout; the private key goes in the file above)

creation_rules:
  - path_regex: secrets/.*\.yaml$
    age:
      - age1REPLACE_WITH_YOUR_AGE_PUBLIC_KEY
