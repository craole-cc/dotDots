# Nix build results
result
result-*

# direnv cache
.direnv/

# Local environment overrides — contains secrets, never commit
.envrc.local

# Encrypted secrets are committed; plaintext YAML is not
secrets/*.yaml
!secrets/*.yaml.enc
!secrets/secrets.yaml.example

