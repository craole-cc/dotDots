#!/bin/sh
# shellcheck enable=all

initialize_bin() {
	DOTS="${PWD:-"$(pwd -P)"}"
	DOTS_CFG="${DOTS}/Configuration"
	DOTS_LIB="${DOTS}/Libraries"
	DOTS_LIB_BASH="${DOTS_LIB}/bash"
	DOTS_LIB_CMD="${DOTS_LIB}/cmd"
	DOTS_LIB_NIX="${DOTS_LIB}/nix"
	DOTS_LIB_NU="${DOTS_LIB}/nushell"
	DOTS_LIB_PS="${DOTS_LIB}/powershell"
	DOTS_LIB_PY="${DOTS_LIB}/python"
	DOTS_LIB_RS="${DOTS_LIB}/rust"
	DOTS_LIB_SH="${DOTS_LIB}/shellscript"
	DOTS_LIB_XML="${DOTS_LIB}/xml"
	export DOTS DOTS_CFG DOTS_LIB DOTS_LIB_BASH DOTS_LIB_CMD DOTS_LIB_NIX DOTS_LIB_NU DOTS_LIB_PS DOTS_LIB_PY DOTS_LIB_RS DOTS_LIB_SH DOTS_LIB_XML

	BINIT_PATH="${DOTS_LIB_SH}/base/binit"
	BINIT_ACTION="--run"
	export BINIT_PATH BINIT_ACTION

	if [ -f "${BINIT_PATH}" ]; then :; else
		printf "direnv: binit not found at %s\n" "${BINIT_PATH}" >&2
	fi

	if [ -x "${BINIT_PATH}" ]; then :; else
		chmod -c +x "${BINIT_PATH}"
	fi

	if . "${BINIT_PATH}"; then :; else
		printf "direnv: Failed to initialize bin at %s\n" "${BINIT_PATH}" >&2
	fi
}

initialize_flake() {
	command -v nix >/dev/null 2>&1 && use flake . --no-pure-eval
}

# . .dotsrc
initialize_bin
initialize_flake
